# EduConnect Configuration Template
# ===============================

# 1. AI API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Database (MongoDB Atlas URI)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGO_URI=mongodb://localhost:27017/educonnect

# 3. Security
SECRET_KEY=educonnect_secret_key_123

# 4. Email (for password reset/verification)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
